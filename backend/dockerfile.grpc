FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

COPY backend/services/grpc/grpc.csproj backend/services/grpc/
RUN dotnet restore backend/services/grpc/grpc.csproj

COPY backend/services/grpc/ backend/services/grpc/
RUN dotnet publish backend/services/grpc/grpc.csproj -c Release -o /app/publish

FROM mcr.microsoft.com/dotnet/aspnet:10.0 AS runtime
WORKDIR /app
COPY --from=build /app/publish .

EXPOSE 8002
ENTRYPOINT ["dotnet", "grpc.dll"]